# ─── Database ───────────────────────────────────────────────────
# Render PostgreSQL uses auto-generated DATABASE_URL from render.yaml
DATABASE_URL=postgresql://user:password@localhost:5432/delivery_db

# ─── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRY_MINUTES=30
BCRYPT_ROUNDS=12

# ─── Admin ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-admin-password

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_MAX_ATTEMPTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BLOCK_MINUTES=5

# ─── SMTP (for password reset + OTP emails) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ─── Frontend + Backend URLs ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── API Key ───────────────────────────────────────────────────
# Shared secret between mobile app and backend for non-JWT requests
API_KEY=change-this-api-key

# ─── Supabase (Storage for product images + Auth OTP) ──────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_UPLOAD_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# ─── Firebase ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PROJECT_NUMBER=

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=
