# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/delivery_db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRY_MINUTES=30
BCRYPT_ROUNDS=12

# ─── Admin ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-admin-password

# ─── Flask (legacy) ─────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-flask-secret
RAZORPAY_WEBHOOK_SECRET=change-this-webhook-secret
SUPABASE_JWT_SECRET=change-this-supabase-jwt-secret

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_MAX_ATTEMPTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BLOCK_MINUTES=5

# ─── Frontend ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
